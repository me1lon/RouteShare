<Page x:Class="RouteShare.UI.AdminPanelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AdminPanelPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="40,0">
                <Button Content="RouteShare" Click="FindTrip_Click" Background="Transparent" BorderThickness="0" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#333333" Padding="0" Cursor="Hand"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Margin="0,0,10,0">
                        <Button Content="Знайти поїздку" Click="FindTrip_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15">
                        <Button Content="Управління поїздками" Click="ManageTrips_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                </StackPanel>

                <Grid HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="UnauthHeader" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Visibility="Visible">
                        <Button Content="Увійти" Click="LoginNav_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>

                    <StackPanel x:Name="AuthHeader" Orientation="Horizontal" Visibility="Collapsed">
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Margin="0,0,15,0">
                            <Button Content="Адмін" Click="Profile_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                        </Border>
                        <Button Click="ProfileDropdown_Click" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="28" Foreground="#333333" Margin="0,0,5,0"/>
                                <TextBlock Text="▼" FontSize="12" Foreground="#333333" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Popup x:Name="LogoutPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" Margin="0,10,0,0">
                        <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Padding="5">
                            <Button Content="Вийти" Click="Logout_Click" Background="#E6E6E6" BorderThickness="0" Padding="15,8" Foreground="#333333"/>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" HorizontalAlignment="Center" Width="1000">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,30,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Height="45">
                    <Button Content="Завантажити з JSON" Click="LoadJson_Click" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
                </Border>
                <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Height="45">
                    <Button Content="Зберегти в JSON" Click="SaveJson_Click" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
                </Border>
            </Grid>

            <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Margin="0,0,0,50">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="UsersTabBorder" Grid.Column="0" Background="#E6E6E6" CornerRadius="10,0,0,0" BorderBrush="#CCCCCC" BorderThickness="0,0,1,1">
                            <Button Content="Користувачі" Click="ShowUsers_Click" Background="Transparent" BorderThickness="0" FontSize="18" FontWeight="SemiBold" Foreground="#333333"/>
                        </Border>
                        <Border x:Name="TripsTabBorder" Grid.Column="1" Background="Transparent" CornerRadius="0,10,0,0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                            <Button Content="Усі поїздки" Click="ShowTrips_Click" Background="Transparent" BorderThickness="0" FontSize="18" FontWeight="SemiBold" Foreground="#555555"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">
                        <ScrollViewer x:Name="UsersContainer" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="UsersList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="25,15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Name}" Grid.Column="0" FontSize="16" Foreground="#333333" VerticalAlignment="Center"/>

                                                <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="15,0"/>

                                                <TextBlock Text="{Binding Email}" Grid.Column="2" FontSize="16" Foreground="#555555" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                <Border Grid.Column="3" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="15,0"/>

                                                <TextBlock Text="Пасажир" Grid.Column="4" FontSize="16" Foreground="#555555" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                <Border Grid.Column="5" Background="#E6E6E6" CornerRadius="8" Width="140" Height="40">
                                                    <Button Content="Заблокувати" Click="BlockUser_Click" Background="Transparent" BorderThickness="0" FontSize="15" Foreground="#333333"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <ScrollViewer x:Name="TripsContainer" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="TripsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="25,15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="2.5*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DepartureCity}" FontSize="16" Foreground="#333333"/>
                                                    <TextBlock Text=" → " FontSize="16" Foreground="#333333" Margin="5,0"/>
                                                    <TextBlock Text="{Binding ArrivalCity}" FontSize="16" Foreground="#333333"/>
                                                </StackPanel>

                                                <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="15,0"/>

                                                <TextBlock Text="{Binding Date, StringFormat=\{0:dd.MM.yyyy\}}" Grid.Column="2" FontSize="16" Foreground="#333333" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                <Border Grid.Column="3" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="15,0"/>

                                                <StackPanel Orientation="Horizontal" Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="Водій: " FontSize="16" Foreground="#777777"/>
                                                    <TextBlock Text="{Binding Driver.Name}" FontSize="16" FontWeight="SemiBold" Foreground="#333333"/>
                                                </StackPanel>

                                                <Border Grid.Column="5" Background="#E6E6E6" CornerRadius="8" Width="120" Height="40">
                                                    <Button Content="Видалити" Click="DeleteTrip_Click" Background="Transparent" BorderThickness="0" FontSize="15" Foreground="#333333"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>