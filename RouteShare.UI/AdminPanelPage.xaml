<Page x:Class="RouteShare.UI.AdminPanelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AdminPanelPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="40,0">
                <TextBlock Text="RouteShare" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#333333"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Margin="0,0,10,0">
                        <Button Content="Знайти поїздку" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15">
                        <Button Content="Управління поїздками" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="👤" FontSize="28" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#333333"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" HorizontalAlignment="Center" Width="1000">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,30,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Height="45">
                    <Button Content="Завантажити з JSON" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
                </Border>

                <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Height="45">
                    <Button Content="Зберегти в JSON" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
                </Border>
            </Grid>

            <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Margin="0,0,0,50">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#E6E6E6" CornerRadius="10,0,0,0" BorderBrush="#CCCCCC" BorderThickness="0,0,1,1">
                            <TextBlock Text="Користувачі" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#333333"/>
                        </Border>

                        <Border Grid.Column="1" Background="Transparent" CornerRadius="0,10,0,0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                            <TextBlock Text="Усі поїздки" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555555"/>
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="25,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="1. Андрій Шевченко" Grid.Column="0" FontSize="16" Foreground="#333333" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="15,0"/>
                                    <TextBlock Text="andriishevschenko@gmail.com" Grid.Column="2" FontSize="16" Foreground="#555555" VerticalAlignment="Center"/>
                                    <Border Grid.Column="3" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="15,0"/>
                                    <TextBlock Text="Пасажир" Grid.Column="4" FontSize="16" Foreground="#555555" VerticalAlignment="Center"/>

                                    <Border Grid.Column="5" Background="#E6E6E6" CornerRadius="8" Width="140" Height="40">
                                        <Button Content="Заблокувати" Background="Transparent" BorderThickness="0" FontSize="15" Foreground="#333333"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="25,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="2. Іван Франко" Grid.Column="0" FontSize="16" Foreground="#333333" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="15,0"/>
                                    <TextBlock Text="ivanfranko@gmail.com" Grid.Column="2" FontSize="16" Foreground="#555555" VerticalAlignment="Center"/>
                                    <Border Grid.Column="3" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="15,0"/>
                                    <TextBlock Text="Водій" Grid.Column="4" FontSize="16" Foreground="#555555" VerticalAlignment="Center"/>

                                    <Border Grid.Column="5" Background="#E6E6E6" CornerRadius="8" Width="140" Height="40">
                                        <Button Content="Заблокувати" Background="Transparent" BorderThickness="0" FontSize="15" Foreground="#333333"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="25,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="3. Леся Українка" Grid.Column="0" FontSize="16" Foreground="#333333" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="15,0"/>
                                    <TextBlock Text="lesyaukrainka@gmail.com" Grid.Column="2" FontSize="16" Foreground="#555555" VerticalAlignment="Center"/>
                                    <Border Grid.Column="3" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="15,0"/>
                                    <TextBlock Text="Пасажир" Grid.Column="4" FontSize="16" Foreground="#555555" VerticalAlignment="Center"/>

                                    <Border Grid.Column="5" Background="#E6E6E6" CornerRadius="8" Width="140" Height="40">
                                        <Button Content="Заблокувати" Background="Transparent" BorderThickness="0" FontSize="15" Foreground="#333333"/>
                                    </Border>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>