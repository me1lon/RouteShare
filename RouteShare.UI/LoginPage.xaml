<Page x:Class="RouteShare.UI.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoginPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="40,0">
                <TextBlock Text="RouteShare" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#333333"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Margin="0,0,10,0">
                        <Button Content="Знайти поїздку" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15">
                        <Button Content="Управління поїздками" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="👤" FontSize="28" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#333333"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="450" Margin="0,0,0,50">
            <TextBlock Text="RouteShare" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="#333333"/>
            <TextBlock Text="Увійти в обліковий запис" FontSize="18" Foreground="#777777" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <TextBlock Text="Имейл" FontSize="16" Foreground="#333333" Margin="0,0,0,8"/>
            <Border Background="#E6E6E6" CornerRadius="10" Height="45" Margin="0,0,0,25">
                <TextBox Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="15,0" FontSize="16" Foreground="#333333"/>
            </Border>

            <TextBlock Text="Пароль" FontSize="16" Foreground="#333333" Margin="0,0,0,8"/>
            <Border Background="#E6E6E6" CornerRadius="10" Height="45" Margin="0,0,0,25">
                <PasswordBox Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="15,0" FontSize="16" Foreground="#333333"/>
            </Border>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Height="45" Margin="0,0,0,25">
                <Button Content="Вхід" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
            </Border>

            <TextBlock HorizontalAlignment="Center" FontSize="14" Margin="0,0,0,15">
                <Run Text="Новий користувач? " Foreground="#777777"/>
                <Hyperlink TextDecorations="Underline" Foreground="#333333">Зареєструватися</Hyperlink>
            </TextBlock>

            <TextBlock HorizontalAlignment="Center" FontSize="14">
                <Hyperlink TextDecorations="Underline" Foreground="#333333">Продовжити як Гість</Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>