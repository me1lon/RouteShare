<Page x:Class="RouteShare.UI.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="MainPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="40,0">
                <TextBlock Text="RouteShare" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#333333"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Margin="0,0,10,0">
                        <Button Content="Знайти поїздку" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15">
                        <Button Content="Управління поїздками" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="👤" FontSize="28" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#333333"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel MaxWidth="1000" Margin="40,30,40,50">

                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Height="60" Margin="0,0,0,30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Text="Виїжджаєте з" Grid.Column="0" VerticalAlignment="Center" BorderThickness="0" Background="Transparent" Foreground="#333333" FontSize="16" Padding="15,0"/>

                        <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0">
                            <TextBox Text="Прямуєте до" VerticalAlignment="Center" BorderThickness="0" Background="Transparent" Foreground="#333333" FontSize="16" Padding="15,0"/>
                        </Border>

                        <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0">
                            <TextBox Text="Сьогодні" VerticalAlignment="Center" BorderThickness="0" Background="Transparent" Foreground="#333333" FontSize="16" Padding="15,0"/>
                        </Border>

                        <Border Grid.Column="3" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0">
                            <TextBox Text="1 пасажир" VerticalAlignment="Center" BorderThickness="0" Background="Transparent" Foreground="#333333" FontSize="16" Padding="15,0"/>
                        </Border>

                        <Border Grid.Column="4" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Background="#E6E6E6" CornerRadius="0,10,10,0">
                            <Button Content="Шукати" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
                        </Border>
                    </Grid>
                </Border>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Padding="25" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" HorizontalAlignment="Left">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="14:00" Grid.Row="0" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>
                            <TextBlock Text="- - - - - - - - - - - - - - -" Grid.Row="0" Grid.Column="1" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="15,0,15,10"/>
                            <TextBlock Text="19:00" Grid.Row="0" Grid.Column="2" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>

                            <TextBlock Text="Будапешт" Grid.Row="1" Grid.Column="0" FontSize="14" Foreground="#777777"/>
                            <TextBlock Text="Прага" Grid.Row="1" Grid.Column="2" FontSize="14" Foreground="#777777"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,40,0">
                            <TextBlock Text="1200 грн" FontSize="22" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Right" Margin="0,0,0,5"/>
                            <TextBlock Text="4 місця залишилось" FontSize="14" Foreground="#777777" HorizontalAlignment="Right"/>
                        </StackPanel>

                        <Border Grid.Column="2" Background="#E6E6E6" CornerRadius="10" Width="150" Height="50" VerticalAlignment="Center">
                            <Button Content="Забронювати" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
                        </Border>
                    </Grid>
                </Border>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Padding="25" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" HorizontalAlignment="Left">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="14:00" Grid.Row="0" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>
                            <TextBlock Text="- - - - - - - - - - - - - - -" Grid.Row="0" Grid.Column="1" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="15,0,15,10"/>
                            <TextBlock Text="19:00" Grid.Row="0" Grid.Column="2" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>

                            <TextBlock Text="Будапешт" Grid.Row="1" Grid.Column="0" FontSize="14" Foreground="#777777"/>
                            <TextBlock Text="Прага" Grid.Row="1" Grid.Column="2" FontSize="14" Foreground="#777777"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,40,0">
                            <TextBlock Text="1200 грн" FontSize="22" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Right" Margin="0,0,0,5"/>
                            <TextBlock Text="4 місця залишилось" FontSize="14" Foreground="#777777" HorizontalAlignment="Right"/>
                        </StackPanel>

                        <Border Grid.Column="2" Background="#E6E6E6" CornerRadius="10" Width="150" Height="50" VerticalAlignment="Center">
                            <Button Content="Забронювати" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
                        </Border>
                    </Grid>
                </Border>

                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Padding="25" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" HorizontalAlignment="Left">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="14:00" Grid.Row="0" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>
                            <TextBlock Text="- - - - - - - - - - - - - - -" Grid.Row="0" Grid.Column="1" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="15,0,15,10"/>
                            <TextBlock Text="19:00" Grid.Row="0" Grid.Column="2" FontSize="16" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,10"/>

                            <TextBlock Text="Будапешт" Grid.Row="1" Grid.Column="0" FontSize="14" Foreground="#777777"/>
                            <TextBlock Text="Прага" Grid.Row="1" Grid.Column="2" FontSize="14" Foreground="#777777"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,40,0">
                            <TextBlock Text="1200 грн" FontSize="22" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Right" Margin="0,0,0,5"/>
                            <TextBlock Text="4 місця залишилось" FontSize="14" Foreground="#777777" HorizontalAlignment="Right"/>
                        </StackPanel>

                        <Border Grid.Column="2" Background="#E6E6E6" CornerRadius="10" Width="150" Height="50" VerticalAlignment="Center">
                            <Button Content="Забронювати" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>