<Page x:Class="RouteShare.UI.ControlTripsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ControlTripsPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="40,0">
                <TextBlock Text="RouteShare" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#333333"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Margin="0,0,10,0">
                        <Button Content="Знайти поїздку" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15">
                        <Button Content="Управління поїздками" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="👤" FontSize="28" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#333333"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="40,30,40,50" MaxWidth="1200">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" VerticalAlignment="Top">
                <StackPanel Margin="20">
                    <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,20">
                        <TextBlock Text="Створити поїздку" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#333333"/>
                    </Border>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Звідки:" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Куди:" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Дата і час:" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Кількість:" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Ціна (грн):" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0"/>
                        </Border>
                    </Grid>

                    <Border Background="#E6E6E6" CornerRadius="10" Height="45">
                        <Button Content="Створити" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                        <TextBlock Text="Мої поїздки" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#333333"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="20 Квітня" FontSize="16" Foreground="#333333" HorizontalAlignment="Center"/>
                                        <TextBlock Text="2026" FontSize="14" Foreground="#777777" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="10,0" Height="40"/>

                                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="14:00" Grid.Row="0" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="#333333"/>
                                        <TextBlock Text="- - - - - - - - - - - - - - -" Grid.Row="0" Grid.Column="1" Foreground="#AAAAAA" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Text="19:00" Grid.Row="0" Grid.Column="2" FontSize="16" FontWeight="SemiBold" Foreground="#333333"/>

                                        <TextBlock Text="Будапешт" Grid.Row="1" Grid.Column="0" FontSize="14" Foreground="#777777" Margin="0,5,0,0"/>
                                        <TextBlock Text="Прага" Grid.Row="1" Grid.Column="2" FontSize="14" Foreground="#777777" Margin="0,5,0,0"/>
                                    </Grid>

                                    <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Margin="0,0,20,0" HorizontalAlignment="Right" Height="40"/>

                                    <Grid Grid.Column="3" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                                            <TextBlock Text="1200 грн" FontSize="18" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center"/>
                                            <TextBlock Text="4 місця залишилось" FontSize="12" Foreground="#777777" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="10" Width="120" Height="40">
                                            <Button Content="Скасувати" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#333333"/>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="20 Квітня" FontSize="16" Foreground="#333333" HorizontalAlignment="Center"/>
                                        <TextBlock Text="2026" FontSize="14" Foreground="#777777" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="10,0" Height="40"/>
                                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="14:00" Grid.Row="0" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="#333333"/>
                                        <TextBlock Text="- - - - - - - - - - - - - - -" Grid.Row="0" Grid.Column="1" Foreground="#AAAAAA" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Text="19:00" Grid.Row="0" Grid.Column="2" FontSize="16" FontWeight="SemiBold" Foreground="#333333"/>
                                        <TextBlock Text="Будапешт" Grid.Row="1" Grid.Column="0" FontSize="14" Foreground="#777777" Margin="0,5,0,0"/>
                                        <TextBlock Text="Прага" Grid.Row="1" Grid.Column="2" FontSize="14" Foreground="#777777" Margin="0,5,0,0"/>
                                    </Grid>
                                    <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Margin="0,0,20,0" HorizontalAlignment="Right" Height="40"/>
                                    <Grid Grid.Column="3" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                                            <TextBlock Text="1200 грн" FontSize="18" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center"/>
                                            <TextBlock Text="4 місця залишилось" FontSize="12" Foreground="#777777" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="10" Width="120" Height="40">
                                            <Button Content="Скасувати" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#333333"/>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>