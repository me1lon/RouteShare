<Page x:Class="RouteShare.UI.ControlTripsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ControlTripsPage" Background="White">

    <Page.Resources>
        <Style TargetType="TextBox" x:Key="PlaceholderTextBox">
            <Setter Property="Foreground" Value="#3A3A3A"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <TextBlock Text="{TemplateBinding Tag}" Foreground="#888888" Padding="{TemplateBinding Padding}" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="40,0">
                <Button Content="RouteShare" Click="FindTrip_Click" Background="Transparent" BorderThickness="0" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#333333" Padding="0" Cursor="Hand"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Margin="0,0,10,0">
                        <Button Content="Знайти поїздку" Click="FindTrip_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15">
                        <Button Content="Управління поїздками" Click="ManageTrips_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                </StackPanel>

                <Grid HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="UnauthHeader" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Visibility="Visible">
                        <Button Content="Увійти" Click="LoginNav_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>

                    <StackPanel x:Name="AuthHeader" Orientation="Horizontal" Visibility="Collapsed">
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Margin="0,0,15,0">
                            <Button Content="Адмін" Click="Profile_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                        </Border>
                        <Button Click="ProfileDropdown_Click" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="28" Foreground="#333333" Margin="0,0,5,0"/>
                                <TextBlock Text="▼" FontSize="12" Foreground="#333333" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Popup x:Name="LogoutPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" Margin="0,10,0,0">
                        <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Padding="5">
                            <Button Content="Вийти" Click="Logout_Click" Background="#E6E6E6" BorderThickness="0" Padding="15,8" Foreground="#333333"/>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="40,30,40,50" MaxWidth="1200">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" VerticalAlignment="Top">
                <StackPanel Margin="20">
                    <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="0,0,0,15" Margin="0,0,0,20">
                        <TextBlock Text="Створити поїздку" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#333333"/>
                    </Border>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Звідки:" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox x:Name="DepartureInput" Text="Прага" Tag="Прага" Foreground="#888888" GotFocus="RemoveText" LostFocus="AddText" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" FontSize="14"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Куди:" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox x:Name="ArrivalInput" Text="Будапешт" Tag="Будапешт" Foreground="#888888" GotFocus="RemoveText" LostFocus="AddText" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" FontSize="14"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Відбуття:" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox x:Name="DepDateInput" Text="дд.мм.рррр" Tag="дд.мм.рррр" Foreground="#888888" GotFocus="RemoveText" LostFocus="AddText" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" FontSize="14"/>
                        </Border>
                        <Border Grid.Column="3" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox x:Name="DepTimeInput" Text="00:00" Tag="00:00" Foreground="#888888" GotFocus="RemoveText" LostFocus="AddText" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" FontSize="14"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Прибуття:" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox x:Name="ArrDateInput" Text="дд.мм.рррр" Tag="дд.мм.рррр" Foreground="#888888" GotFocus="RemoveText" LostFocus="AddText" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" FontSize="14"/>
                        </Border>
                        <Border Grid.Column="3" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox x:Name="ArrTimeInput" Text="00:00" Tag="00:00" Foreground="#888888" GotFocus="RemoveText" LostFocus="AddText" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" FontSize="14"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Місця:" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox x:Name="SeatsInput" Text="12" Tag="12" Foreground="#888888" GotFocus="RemoveText" LostFocus="AddText" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" FontSize="14"/>
                        </Border>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Ціна (грн):" VerticalAlignment="Center" FontSize="14" Foreground="#555555"/>
                        <Border Grid.Column="1" Background="#E6E6E6" CornerRadius="8" Height="35">
                            <TextBox x:Name="PriceInput" Text="1200" Tag="1200" Foreground="#888888" GotFocus="RemoveText" LostFocus="AddText" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" FontSize="14"/>
                        </Border>
                    </Grid>

                    <Border Background="#E6E6E6" CornerRadius="10" Height="45" Margin="0,10,0,0">
                        <Button Content="Створити" Click="CreateTrip_Click" Background="Transparent" BorderThickness="0" FontSize="16" FontWeight="SemiBold" Foreground="#333333"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                        <TextBlock Text="Мої поїздки" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#333333"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TripsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,1" Padding="20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Date, StringFormat=\{0:dd.MM.yyyy\}}" FontSize="16" Foreground="#333333" HorizontalAlignment="Center"/>
                                            </StackPanel>

                                            <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Margin="10,0" Height="40"/>

                                            <Grid Grid.Column="2" VerticalAlignment="Center" Margin="10,0,20,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Date, StringFormat=\{0:HH:mm\}}" Grid.Row="0" Grid.Column="0" FontSize="16" FontWeight="SemiBold" Foreground="#333333"/>
                                                <TextBlock Text="{Binding DepartureCity}" Grid.Row="1" Grid.Column="0" FontSize="14" Foreground="#777777" Margin="0,5,0,0"/>

                                                <TextBlock Text="- - - - - - - - - - -" Grid.Row="0" Grid.Column="1" Foreground="#AAAAAA" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                <TextBlock Text="{Binding ArrivalDate, StringFormat=\{0:HH:mm\}}" Grid.Row="0" Grid.Column="2" FontSize="16" FontWeight="SemiBold" Foreground="#333333" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding ArrivalCity}" Grid.Row="1" Grid.Column="2" FontSize="14" Foreground="#777777" Margin="0,5,0,0" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <Border Grid.Column="3" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Padding="20,0,0,0" VerticalAlignment="Center">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Price, StringFormat=\{0\} грн}" FontSize="18" FontWeight="Bold" Foreground="#333333" HorizontalAlignment="Center"/>
                                                        <TextBlock Loaded="SeatsText_Loaded" FontSize="12" Foreground="#777777" HorizontalAlignment="Center"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <Border Background="#E6E6E6" CornerRadius="10" Width="120" Height="40" Margin="0,0,0,5">
                                                            <Button Content="Скасувати" Click="CancelTrip_Click" Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#333333"/>
                                                        </Border>
                                                        <TextBlock Loaded="RoleText_Loaded" FontSize="12" Foreground="#888888" HorizontalAlignment="Center" TextAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>