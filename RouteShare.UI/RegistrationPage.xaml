<Page x:Class="RouteShare.UI.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="RegistrationPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="40,0">
                <Button Content="RouteShare" Click="FindTrip_Click" Background="Transparent" BorderThickness="0" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#333333" Padding="0" Cursor="Hand"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Margin="0,0,10,0">
                        <Button Content="Знайти поїздку" Click="FindTrip_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15">
                        <Button Content="Управління поїздками" Click="ManageTrips_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>
                </StackPanel>

                <Grid HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border x:Name="UnauthHeader" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Visibility="Visible">
                        <Button Content="Увійти" Click="LoginNav_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                    </Border>

                    <StackPanel x:Name="AuthHeader" Orientation="Horizontal" Visibility="Collapsed">
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="15" Margin="0,0,15,0">
                            <Button Content="Адмін" Click="Profile_Click" Background="Transparent" BorderThickness="0" Padding="15,8" Foreground="#555555"/>
                        </Border>
                        <Button Click="ProfileDropdown_Click" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="28" Foreground="#333333" Margin="0,0,5,0"/>
                                <TextBlock Text="▼" FontSize="12" Foreground="#333333" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Popup x:Name="LogoutPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" Margin="0,10,0,0">
                        <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Padding="5">
                            <Button Content="Вийти" Click="Logout_Click" Background="#E6E6E6" BorderThickness="0" Padding="15,8" Foreground="#333333"/>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="450" Margin="0,0,0,50">
            <TextBlock Text="RouteShare" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="#333333"/>
            <TextBlock Text="Новий обліковий запис" FontSize="18" Foreground="#777777" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Прізвище та Ім'я" FontSize="16" Foreground="#333333" Margin="0,0,0,8"/>
            <Border Background="#E6E6E6" CornerRadius="10" Height="45" Margin="0,0,0,20">
                <TextBox x:Name="NameTextBox" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="15,0" FontSize="16" Foreground="#333333"/>
            </Border>

            <TextBlock Text="Имейл" FontSize="16" Foreground="#333333" Margin="0,0,0,8"/>
            <Border Background="#E6E6E6" CornerRadius="10" Height="45" Margin="0,0,0,20">
                <TextBox x:Name="EmailTextBox" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="15,0" FontSize="16" Foreground="#333333"/>
            </Border>

            <TextBlock Text="Пароль" FontSize="16" Foreground="#333333" Margin="0,0,0,8"/>
            <Border Background="#E6E6E6" CornerRadius="10" Height="45" Margin="0,0,0,20">
                <PasswordBox x:Name="PasswordBoxInput" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="15,0" FontSize="16" Foreground="#333333"/>
            </Border>

            <TextBlock Text="Підтвердіть пароль" FontSize="16" Foreground="#333333" Margin="0,0,0,8"/>
            <Border Background="#E6E6E6" CornerRadius="10" Height="45" Margin="0,0,0,15">
                <PasswordBox x:Name="ConfirmPasswordBoxInput" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="15,0" FontSize="16" Foreground="#333333"/>
            </Border>

            <TextBlock x:Name="ErrorText" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="10" Height="45" Margin="0,0,0,25">
                <Button Content="Зареєструватися" Click="Register_Click" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#333333"/>
            </Border>

            <TextBlock HorizontalAlignment="Center" FontSize="14" Margin="0,0,0,15">
                <Run Text="Вже є обліковий запис? " Foreground="#777777"/>
                <Hyperlink Click="Login_Click" TextDecorations="Underline" Foreground="#333333">Увійти</Hyperlink>
            </TextBlock>

            <TextBlock HorizontalAlignment="Center" FontSize="14">
                <Hyperlink Click="Guest_Click" TextDecorations="Underline" Foreground="#333333">Продовжити як Гість</Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>